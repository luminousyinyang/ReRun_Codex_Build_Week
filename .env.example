# Server-only. Do not prefix secrets with NEXT_PUBLIC_.
# Leave blank to run the deterministic bundled demo without live generation.
OPENAI_API_KEY=

# Optional: used by the live-generation API routes. GPT-5.6 access may be
# restricted by project; set this to a model your project can access if needed.
OPENAI_MODEL=gpt-5.6
OPENAI_IMAGE_MODEL=
OPENAI_TTS_MODEL=

# Optional future persistence/deployment settings. Demo mode must not require them.
NEXT_PUBLIC_APP_URL=http://localhost:3000
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
